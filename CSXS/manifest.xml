        </Resources>
        <Lifecycle><AutoVisible>true</AutoVisible></Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>MTAG Easing</Menu>
          <Geometry>
            <Size><Height>400</Height><Width>300</Width></Size>
