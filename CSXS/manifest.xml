    <!-- Dedicated (nameless) settings panel for the Motion Toolbar / macros
         panel. No <Menu> element, so it never appears in AE's Window menu —
         it's only reachable via the panel's ⚙ button. -->
    <Extension Id="com.motiontoolbar.panel.toolbarsettings">
      <HostList><Host Name="AEFT" /></HostList>
      <DispatchInfo>
