<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.motiontoolbar.panel" ExtensionBundleVersion="1.0.1" ExtensionBundleName="MTAG" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  
  <ExtensionList>
    <Extension Id="com.motiontoolbar.panel.main" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.secondary" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.easing" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.color" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.gifs" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.gifsettings" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.switch" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.dialog" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.toolbarsettings" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.easingsettings" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.cloud" Version="1.0.0" />
  </ExtensionList>
  
  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="15.0" />
      <!-- Bundle-level default hosts. Per-extension <HostList> blocks inside each
           <Extension> below OVERRIDE this list to scope panels: the AE panels use
           AEFT only, MTAG Switch uses ILST+PHXS. This is the modern CEP 7.0+ form
           (NOT the legacy <DispatchInfo Host="…"> attribute, which the CSXS 7.0
           validator rejects and which nukes the whole bundle). Do not mix the
           two mechanisms. -->
      <Host Name="ILST" Version="24.0" />
      <Host Name="PHXS" Version="24.0" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="7.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  
  <DispatchInfoList>
    
    <Extension Id="com.motiontoolbar.panel.main">
      <HostList><Host Name="AEFT" /></HostList>
      <DispatchInfo>
        <Resources>
          <MainPath>./dist/index.html</MainPath> 
          <ScriptPath>./jsx/hostscript.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle><AutoVisible>true</AutoVisible></Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>MTAG Toolbar</Menu>
          <Geometry>
            <Size><Height>600</Height><Width>300</Width></Size>
            <MinSize><Height>200</Height><Width>40</Width></MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>

    <Extension Id="com.motiontoolbar.panel.secondary">
      <HostList><Host Name="AEFT" /></HostList>
      <DispatchInfo>
        <Resources>
          <MainPath>./dist/index.html</MainPath> 
