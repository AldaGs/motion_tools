<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.motiontoolbar.panel" ExtensionBundleVersion="1.0.0" ExtensionBundleName="Motion Toolbar" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  
  <ExtensionList>
    <Extension Id="com.motiontoolbar.panel.main" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.secondary" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.easing" Version="1.0.0" />
    <Extension Id="com.motiontoolbar.panel.dialog" Version="1.0.0" />
  </ExtensionList>
  
  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="15.0" /> 
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="7.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  
  <DispatchInfoList>
    
    <Extension Id="com.motiontoolbar.panel.main">
      <DispatchInfo>
        <Resources>
          <MainPath>./dist/index.html</MainPath> 
          <ScriptPath>./jsx/hostscript.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--allow-file-access</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle><AutoVisible>true</AutoVisible></Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Motion Toolbar</Menu>
          <Geometry>
            <Size><Height>600</Height><Width>300</Width></Size>
            <MinSize><Height>200</Height><Width>40</Width></MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>

    <Extension Id="com.motiontoolbar.panel.secondary">
      <DispatchInfo>
        <Resources>
          <MainPath>./dist/index.html</MainPath> 
          <ScriptPath>./jsx/hostscript.jsx</ScriptPath>
